# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# API 代理地址（可选，默认为 OpenAI 官方地址）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型配置
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.7

# MCP 配置（第4期）
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:9123/mcp

# Multi-Agent 配置（第6期）
MULTI_AGENT_ENABLED=false

# Memory 配置（第7期）
MEMORY_ENABLED=true
MEMORY_DIR=app/sessions/memory
MEMORY_USER_ID=default
MAX_LTM_FACTS=50

# Skill 配置（第8期）
SKILLS_ENABLED=true
SKILLS_DIR=app/agent/skills/definitions

# Evaluation 配置（第9期，离线评估工具）
EVAL_DATASET_PATH=app/evaluation/cases.json
EVAL_USE_JUDGE=true
EVAL_PASS_THRESHOLD=0.6

# RAG 配置（第5期）
EMBEDDING_MODEL=text-embedding-3-small
KB_DIR=app/agent/rag/knowledge
# 向量后端：numpy（手写余弦，教学透明）/ chroma（向量数据库，生产代表）
RAG_BACKEND=numpy
# NumpyBackend 索引文件
KB_INDEX_PATH=app/sessions/kb_index.json
# ChromaBackend 持久化目录 + collection
CHROMA_PERSIST_DIR=app/sessions/chroma
CHROMA_COLLECTION=ecom_kb
POLICY_RAG_MIN_SCORE=0.2

# Agent 深化：售后工单 / Human-in-the-Loop
AFTER_SALE_ENABLED=true
AFTER_SALE_CASE_PATH=app/sessions/after_sale_cases.json
# 低于该金额且无其他风险信号时允许自动审批
AFTER_SALE_AUTO_APPROVE_MAX_AMOUNT=200
# 达到该金额时进入高风险人工升级
AFTER_SALE_HIGH_RISK_AMOUNT=2000
